<div class="row justify-content-center">
  <div class="col-md-6">
    <h1 class="mb-4">New Place</h1>

    <form action="/places" method="post">
      <%= csrf_meta_tags %>

      <div class="mb-3">
        <label for="name_input" class="form-label">Name</label>
        <input type="text" name="name" id="name_input" class="form-control" placeholder="e.g. Mexico City">
      </div>

      <div class="d-grid gap-2">
        <button class="btn btn-primary">Save Place</button>
        <a href="/places" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>