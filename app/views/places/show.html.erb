<h1><%= @place["name"] %></h1>

<div class="row">
  <% for entry in @entries %>
    <div class="col-sm-12 col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title h5"><%= entry["title"] %></h3>
          <h4 class="text-muted small"><%= entry["occurred_on"] %></h4>
          <% if entry.uploaded_image.attached? %>
            <img src="<%= url_for(entry.uploaded_image) %>" class="img-fluid">
          <% else %>
            <img src="<%= entry["image"] %>" class="img-fluid">
          <% end %>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-4">
  <% @user = User.find_by({ "id" => session["user_id"] }) %>
  <% if @user != nil %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-success">
      <i class="bi bi-plus-lg"></i> New Entry
    </a>
  <% else %>
    <p class="text-muted italic">Log in to make new entries.</p>
  <% end %>
</div>

<p class="mt-3">
  <a href="/places" class="btn btn-outline-secondary btn-sm">Back to All Places</a>
</p>